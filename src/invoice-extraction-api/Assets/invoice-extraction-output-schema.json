{
  "name": "extract_proof_of_purchase",
  "strict": true,
  "schema": {
    "type": "object",
    "properties": {
      "results": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "document_title": {
              "type": ["string", "null"]
            },
            "invoice_date": {
              "type": ["string", "null"]
            },
            "invoice_number": {
              "type": ["string", "null"]
            },
            "currency_code": {
              "type": ["string", "null"]
            },
            "gross_amount": {
              "type": ["number", "null"]
            },
            "seller": {
              "type": "object",
              "properties": {
                "name": {
                  "type": ["string", "null"]
                },
                "city": {
                  "type": ["string", "null"]
                },
                "state": {
                  "type": ["string", "null"]
                },
                "country": {
                  "type": ["string", "null"]
                }
              },
              "required": ["name", "city", "country"],
              "additionalProperties": false
            },
            "end_customer": {
              "type": "object",
              "properties": {
                "name": {
                  "type": ["string", "null"]
                },
                "city": {
                  "type": ["string", "null"]
                },
                "state": {
                  "type": ["string", "null"]
                },
                "country": {
                  "type": ["string", "null"]
                },
                "email": {
                  "type": ["string", "null"]
                }
              },
              "required": ["country"],
              "additionalProperties": false
            },
            "purchases": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "quantity": {
                    "type": ["number", "null"]
                  },
                  "part_number": {
                    "type": ["string", "null"]
                  },
                  "description": {
                    "type": ["string", "null"]
                  },
                  "serial_numbers": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "unit_price": {
                    "type": ["number", "null"]
                  }
                },
                "required": ["quantity", "description", "serial_numbers", "unit_price"],
                "additionalProperties": false
              }
            }
          },
          "required": [
            "document_title",
            "invoice_date",
            "invoice_number",
            "currency_code",
            "gross_amount",
            "seller",
            "end_customer",
            "purchases"
          ],
          "additionalProperties": false
        }
      }
    },
    "required": ["results"],
    "additionalProperties": false
  }
}
